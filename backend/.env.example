APP_NAME=tool-augmented-ai-backend
ENVIRONMENT=development

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_TOOL_STEPS=6

# MCP tool layer. All backend actions must flow through this endpoint.
MCP_SERVER_URL=https://order-mcp-74afyau24q-uc.a.run.app/mcp
MCP_SERVER_AUTH_TOKEN=
MCP_TOOL_CACHE_SECONDS=60

# Gateway controls
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
